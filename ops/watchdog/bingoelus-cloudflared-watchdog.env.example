# Required service names
PRIMARY_SERVICE=cloudflared
CLONE_SERVICE=cloudflared-clon
CHECK_CLONE=1

# Optional tunnel names/UUIDs (if set, watchdog validates active connection count)
PRIMARY_TUNNEL=
CLONE_TUNNEL=
MIN_CONNECTIONS=4

# Health probes
LOCAL_HEALTH_URL=http://127.0.0.1:3000/healthz
# Example: https://bingo.tudominio.com/healthz
PUBLIC_HEALTH_URL=
CURL_TIMEOUT_SEC=6

# Restart policy
FAILURE_THRESHOLD=3
RESTART_COOLDOWN_SEC=120

# Internal files
STATE_DIR=/var/lib/bingoelus
STATE_FILE=/var/lib/bingoelus/cloudflared-watchdog.state
LOCK_FILE=/var/lock/bingoelus-cloudflared-watchdog.lock
LOG_TAG=bingoelus-watchdog

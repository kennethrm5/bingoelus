# Colon-separated source directories to mirror
SOURCE_DIRS=/opt/bingoelus/ganadores:/opt/bingoelus/servidor/resultados

# Local backup layout
BACKUP_BASE=/opt/bingoelus/backups
MIRROR_DIR=/opt/bingoelus/backups/live
ARCHIVE_DIR=/opt/bingoelus/backups/archives

# Archive/retention policy
ARCHIVE_EVERY_MINUTES=120
RETENTION_DAYS=30

# Optional remote sync via gsutil (recommended in GCP)
# Example: GSUTIL_BUCKET=gs://bingoelus-backups
GSUTIL_BUCKET=
GSUTIL_BIN=gsutil

# Optional fallback via rclone
# Example: RCLONE_TARGET=gdrive:bingoelus
RCLONE_TARGET=
RCLONE_BIN=rclone

# Internal files
STATE_DIR=/var/lib/bingoelus
STATE_FILE=/var/lib/bingoelus/backup.state
LOCK_FILE=/var/lock/bingoelus-backup.lock
LOG_TAG=bingoelus-backup

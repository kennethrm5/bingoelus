{
  "name": "bingoelus",
  "version": "1.1.0",
  "description": "Juego de bingo personalizado con frases - gestor Electron, jugadores por navegador",
  "author": "@kennethrm5",
  "main": "main.js",
  "scripts": {
    "start": "electron .",
    "dist": "set CSC_IDENTITY_AUTO_DISCOVERY=false && electron-builder --win"
  },
  "dependencies": {
    "express": "^4.18.3"
  },
  "devDependencies": {
    "electron": "^28.0.0",
    "electron-builder": "^24.13.3"
  },
  "build": {
    "appId": "com.kennethrm5.bingoelus",
    "productName": "Bingoelus",
    "asar": false,
    "win": {
      "target": [
        {
          "target": "nsis",
          "arch": [
            "x64"
          ]
        }
      ],
      "icon": "media/joelus.ico"
    },
    "nsis": {
      "oneClick": true,
      "perMachine": false,
      "createDesktopShortcut": true,
      "createStartMenuShortcut": true
    },
    "files": [
      "**/*",
      "!resultados/**",
      "!dist/**",
      "!servidor/**",
      "!.gitignore",
      "!*.md"
    ]
  }
}
